# Used server-side by next.config.js to proxy /api/backend/* to your Express API
BACKEND_URL=http://localhost:5000

# Used client-side if you ever call the backend directly without the proxy (not required by default)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional — leave blank to run with analytics disabled
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional — Sentry for frontend error tracking (separate from backend's SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN=
